<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 192 192">
  <rect width="192" height="192" rx="32" fill="#0a0a0a"/>
  <rect width="192" height="192" rx="32" fill="url(#grad)" opacity="0.15"/>
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#e8ff00"/>
      <stop offset="100%" style="stop-color:#ff6b00"/>
